# App
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=replace-with-a-long-random-secret
GITHUB_CLIENT_ID=replace-with-github-oauth-client-id
GITHUB_CLIENT_SECRET=replace-with-github-oauth-client-secret
NEXT_PUBLIC_APP_TITLE=leet-review

# Database
# Local development defaults to SQLite.
DATABASE_MODE=local
LOCAL_SQLITE_PATH=data/dev.sqlite

# Remote D1 mode
# Set DATABASE_MODE=d1-http to use these at runtime and in Drizzle Kit.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_DATABASE_ID=
CLOUDFLARE_D1_TOKEN=

# Optional
LEETCODE_CACHE_PATH=data/leetcode-cache.json
