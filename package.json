{
  "name": "leet-review",
  "private": true,
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "start": "next start",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "test": "vitest run",
    "format": "biome format --write",
    "lint": "biome lint",
    "check": "biome check",
    "auth:generate": "bunx --bun @better-auth/cli@latest generate --config src/lib/auth.ts --output src/db/auth.schema.ts -y",
    "auth:migrate": "bunx --bun @better-auth/cli@latest migrate --config src/lib/auth.ts -y",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:pull": "drizzle-kit pull",
    "db:studio": "drizzle-kit studio",
    "leetcode:cache": "tsx scripts/populate-leetcode-cache.ts",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@base-ui/react": "1.2.0",
    "@hookform/resolvers": "5.2.2",
    "@opennextjs/cloudflare": "^1.19.1",
    "@t3-oss/env-core": "0.13.10",
    "@tanstack/react-devtools": "^0.10.2",
    "@tanstack/react-hotkeys": "^0.9.1",
    "@tanstack/react-hotkeys-devtools": "^0.6.6",
    "@tanstack/react-query": "5.90.21",
    "@tanstack/react-table": "8.21.3",
    "better-auth": "1.4.18",
    "better-sqlite3": "12.6.2",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "date-fns": "4.1.0",
    "drizzle-kit": "0.31.9",
    "drizzle-orm": "0.45.1",
    "embla-carousel-react": "8.6.0",
    "input-otp": "1.4.2",
    "lucide-react": "0.575.0",
    "motion": "12.34.3",
    "next": "16.2.1",
    "next-themes": "0.4.6",
    "nuqs": "2.8.9",
    "radix-ui": "1.4.3",
    "react": "19.2.4",
    "react-day-picker": "9.14.0",
    "react-dom": "19.2.4",
    "react-hook-form": "7.71.2",
    "react-icons": "5.5.0",
    "react-resizable-panels": "4.6.5",
    "recharts": "2.15.4",
    "rxjs": "7.8.2",
    "sonner": "2.0.7",
    "tailwind-merge": "3.5.0",
    "tailwindcss": "4.2.0",
    "ts-fsrs": "5.2.3",
    "tw-animate-css": "1.4.0",
    "vaul": "1.1.2",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.4",
    "@tailwindcss/postcss": "4.2.2",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "22.19.11",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "agentation": "^3.0.2",
    "dotenv": "16.6.1",
    "jsdom": "27.4.0",
    "shadcn": "3.8.5",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "3.2.4",
    "wrangler": "^4.82.0"
  }
}
